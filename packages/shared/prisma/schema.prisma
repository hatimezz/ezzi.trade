// ╔══════════════════════════════════════════════════════════════╗
// ║  EZZI WORLD — Complete Database Schema                      ║
// ║  PostgreSQL via Supabase · Prisma ORM                       ║
// ╚══════════════════════════════════════════════════════════════╝

generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// ENUMS
// ============================================

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  MODERATOR
  VIEWER
}

enum PartnerType {
  INFLUENCER
  AFFILIATE
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InfluencerTier {
  NANO
  MICRO
  MID
  MACRO
}

enum AffiliateTier {
  STARTER
  SILVER
  GOLD
  DIAMOND
}

enum OrderType {
  NFT_PURCHASE
  CAPSULE_PURCHASE
  TOKEN_PURCHASE
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  FRAUD
}

enum PayoutMethod {
  EZZI_COIN
  USDC
  NFT_REWARD
}

enum WithdrawalStatus {
  REQUESTED
  PROCESSING
  COMPLETED
  FAILED
}

// ============================================
// ADMIN SYSTEM
// ============================================

model Admin {
  id               String      @id @default(cuid())
  username         String      @unique
  email            String      @unique
  passwordHash     String
  role             AdminRole   @default(MODERATOR)
  isActive         Boolean     @default(true)
  lastLoginAt      DateTime?
  lastLoginIp      String?
  twoFactorEnabled Boolean     @default(false)
  twoFactorSecret  String?
  loginAttempts    Int         @default(0)
  lockedUntil      DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  auditLogs        AdminAuditLog[]

  @@index([username])
  @@index([email])
}

model AdminAuditLog {
  id        String   @id @default(cuid())
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id])
  action    String
  target    String?
  targetId  String?
  before    Json?
  after     Json?
  ipHash    String
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
}

// ============================================
// SITE SETTINGS (singleton)
// ============================================

model SiteSettings {
  id                 String   @id @default("singleton")
  maintenanceMode    Boolean  @default(false)
  maintenanceMsg     String   @default("EZZI World is undergoing maintenance. Back soon.")
  presaleActive      Boolean  @default(true)
  presalePhase       Int      @default(1)
  presalePrice       Decimal  @default(0.015)  @db.Decimal(10, 6)
  presaleTarget      Decimal  @default(100000) @db.Decimal(18, 2)
  presaleRaised      Decimal  @default(0)      @db.Decimal(18, 2)
  presaleEndDate     DateTime?
  registrationOpen   Boolean  @default(true)
  capsuleOpen        Boolean  @default(true)
  marketplaceOpen    Boolean  @default(true)
  announcementBar    String?
  announcementActive Boolean  @default(false)
  ezziPriceUsd       Decimal  @default(0.015)  @db.Decimal(10, 6)
  solPriceUsd        Decimal  @default(100)    @db.Decimal(10, 2)
  updatedAt          DateTime @updatedAt
  updatedBy          String?
}

// ============================================
// NOTIFICATION SYSTEM
// ============================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
}

// ============================================
// CORE USER MODELS
// ============================================

model User {
  id              String    @id @default(cuid())
  email           String?   @unique
  username        String?   @unique
  displayName     String?
  avatarUrl       String?
  country         String?
  tier            String    @default("FREE")
  isActive        Boolean   @default(true)
  isAdmin         Boolean   @default(false)
  telegramId      String?   @unique
  suspendedAt     DateTime?
  suspendedUntil  DateTime?
  suspendedReason String?
  bannedAt        DateTime?
  bannedReason    String?
  deletedAt       DateTime?
  passwordHash    String?
  loginAttempts   Int       @default(0)
  lockedUntil     DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  wallets          Wallet[]
  sessions         Session[]
  ownedNfts        NFT[]
  listings         MarketplaceListing[] @relation("Seller")
  capsuleOpenings  CapsuleOpening[]
  balance          UserBalance?
  miningSessions   MiningSession[]
  notifications    Notification[]
  presalePurchases PresalePurchase[]

  @@index([email])
  @@index([username])
  @@index([isActive])
  @@index([tier])
  @@index([country])
  @@index([telegramId])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String
  address   String   @unique
  chain     String   @default("solana")
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([address])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  userAgent String?
  ipAddress String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

// ============================================
// WAITLIST
// ============================================

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  country   String?
  source    String?
  referrer  String?
  ipHash    String?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

// ============================================
// NFT + MARKETPLACE MODELS
// ============================================

model Warrior {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  zone        String
  rarity      String
  basePrice   Float
  totalSupply Int
  imageUrl    String
  attack      Int      @default(0)
  defense     Int      @default(0)
  speed       Int      @default(0)
  magic       Int      @default(0)
  miningRate  Float    @default(1)
  lore        String?
  ability     String?
  abilityDesc String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  nfts        NFT[]

  @@index([zone])
  @@index([rarity])
}

model NFT {
  id            String    @id @default(cuid())
  warriorId     String
  tokenId       String?   @unique
  editionNumber Int       @default(1)
  ownerId       String?
  durability    Int       @default(100)
  saleCount     Int       @default(0)
  isStaked      Boolean   @default(false)
  isFlagged     Boolean   @default(false)
  flagReason    String?
  metadataUri   String?
  mintedAt      DateTime?
  mintedBy      String?

  warrior        Warrior             @relation(fields: [warriorId], references: [id])
  owner          User?               @relation(fields: [ownerId], references: [id])
  listing        MarketplaceListing?
  miningSessions MiningSession[]

  @@index([warriorId])
  @@index([ownerId])
  @@index([isStaked])
  @@index([isFlagged])
}

model MarketplaceListing {
  id        String    @id @default(cuid())
  nftId     String    @unique
  sellerId  String
  price     Float
  priceUsd  Float?
  status    String    @default("active")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  soldAt    DateTime?
  buyerId   String?

  nft       NFT       @relation(fields: [nftId], references: [id], onDelete: Cascade)
  seller    User      @relation(fields: [sellerId], references: [id], onDelete: Cascade, name: "Seller")

  @@index([sellerId])
  @@index([status])
  @@index([price])
}

// ============================================
// MINING MODELS
// ============================================

model MiningSession {
  id           String    @id @default(cuid())
  userId       String
  nftId        String
  zone         String
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  earnedAmount Float     @default(0)
  status       String    @default("active")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  nft          NFT       @relation(fields: [nftId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([startedAt])
}

// ============================================
// CAPSULE MODELS
// ============================================

model CapsuleTier {
  id            String   @id @default(cuid())
  name          String   @unique
  displayName   String
  price         Float
  totalSupply   Int
  remaining     Int
  commonRate    Int      @default(0)
  rareRate      Int      @default(0)
  epicRate      Int      @default(0)
  legendaryRate Int      @default(0)
  mythicRate    Int      @default(0)
  ezziRate      Int      @default(0)
  cssClass      String   @default("capsule-core")
  animation     String   @default("rotate")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  openings      CapsuleOpening[]
}

model CapsuleOpening {
  id            String      @id @default(cuid())
  userId        String
  capsuleTierId String
  openedAt      DateTime    @default(now())
  resultType    String
  resultId      String?
  amount        Float?
  rarity        String?
  txHash        String?
  createdAt     DateTime    @default(now())

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  capsuleTier   CapsuleTier @relation(fields: [capsuleTierId], references: [id])

  @@index([userId])
  @@index([capsuleTierId])
  @@index([resultType])
}

// ============================================
// USER BALANCE MODEL
// ============================================

model UserBalance {
  id          String   @id @default(cuid())
  userId      String   @unique
  ezziBalance Float    @default(0)
  totalMined  Float    @default(0)
  totalEarned Float    @default(0)
  totalSpent  Float    @default(0)
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================
// TRANSACTION MODEL
// ============================================

model ProcessedTx {
  id          String    @id @default(cuid())
  txHash      String    @unique
  type        String
  status      String    @default("pending")
  amount      Float
  token       String    @default("SOL")
  fromAddress String
  toAddress   String
  userId      String?
  metadata    Json?
  processedAt DateTime  @default(now())
  confirmedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([txHash])
  @@index([type])
  @@index([status])
  @@index([userId])
  @@index([processedAt])
}

// ============================================
// LIVE EVENTS
// ============================================

model LiveEvent {
  id        String   @id @default(cuid())
  type      String
  message   String
  wallet    String?
  data      Json?
  createdAt DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}

// ============================================
// PRESALE
// ============================================

model PresalePurchase {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletAddress String
  ezziAmount   Decimal   @db.Decimal(18, 2)
  usdAmount    Decimal   @db.Decimal(18, 2)
  solAmount    Decimal?  @db.Decimal(18, 9)
  phase        Int       @default(1)
  pricePerEzzi Decimal   @db.Decimal(10, 6)
  status       String    @default("confirmed")
  txHash       String?   @unique
  refCode      String?
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([phase])
  @@index([status])
  @@index([createdAt])
}

// ============================================
// PARTNER SYSTEM
// ============================================

model PartnerApplication {
  id              String            @id @default(cuid())
  userId          String?
  walletAddress   String
  email           String?
  type            PartnerType
  status          ApplicationStatus @default(PENDING)

  twitterHandle   String?
  followersCount  Int?
  niches          String[]
  language        String            @default("English")
  bestTweetUrl    String?
  whyApply        String?
  estimatedTier   InfluencerTier?

  promoteChannel  String?

  refCode         String            @unique @default(cuid())
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  influencer      Influencer?
  affiliate       Affiliate?

  @@index([status])
  @@index([type])
  @@index([refCode])
}

model Influencer {
  id              String         @id @default(cuid())
  applicationId   String         @unique
  application     PartnerApplication @relation(fields: [applicationId], references: [id])

  twitterHandle   String
  tier            InfluencerTier
  walletAddress   String

  totalSales      Int            @default(0)
  totalEarned     Decimal        @default(0) @db.Decimal(18, 9)
  pendingEarned   Decimal        @default(0) @db.Decimal(18, 9)
  totalClicks     Int            @default(0)

  isActive        Boolean        @default(true)
  isSuspended     Boolean        @default(false)

  activeCampaignId String?
  campaign        Campaign?      @relation(fields: [activeCampaignId], references: [id])

  commissions     Commission[]
  clicks          ReferralClick[]
  withdrawals     Withdrawal[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([twitterHandle])
  @@index([tier])
  @@index([totalSales])
}

model Affiliate {
  id              String         @id @default(cuid())
  applicationId   String         @unique
  application     PartnerApplication @relation(fields: [applicationId], references: [id])

  walletAddress   String
  tier            AffiliateTier  @default(STARTER)

  totalSales      Int            @default(0)
  totalEarned     Decimal        @default(0) @db.Decimal(18, 9)
  pendingEarned   Decimal        @default(0) @db.Decimal(18, 9)
  totalClicks     Int            @default(0)

  isActive        Boolean        @default(true)
  isSuspended     Boolean        @default(false)

  commissions     Commission[]
  clicks          ReferralClick[]
  withdrawals     Withdrawal[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([tier])
  @@index([totalSales])
}

model Commission {
  id              String           @id @default(cuid())

  influencerId    String?
  influencer      Influencer?      @relation(fields: [influencerId], references: [id])
  affiliateId     String?
  affiliate       Affiliate?       @relation(fields: [affiliateId], references: [id])

  orderId         String
  orderType       OrderType
  orderAmount     Decimal          @db.Decimal(18, 9)
  ezziAmount      Decimal          @db.Decimal(18, 9)
  ratePercent     Decimal          @db.Decimal(5, 2)

  status          CommissionStatus @default(PENDING)
  lockedUntil     DateTime
  paidAt          DateTime?
  txSignature     String?

  isFraud         Boolean          @default(false)
  fraudReason     String?

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([influencerId])
  @@index([affiliateId])
  @@index([status])
  @@index([orderId])
}

model ReferralClick {
  id              String      @id @default(cuid())
  refCode         String

  influencerId    String?
  influencer      Influencer? @relation(fields: [influencerId], references: [id])
  affiliateId     String?
  affiliate       Affiliate?  @relation(fields: [affiliateId], references: [id])

  ipHash          String
  userAgent       String?
  convertedAt     DateTime?
  sessionId       String?

  createdAt       DateTime    @default(now())

  @@index([refCode])
  @@index([createdAt])
}

model Withdrawal {
  id              String           @id @default(cuid())

  influencerId    String?
  influencer      Influencer?      @relation(fields: [influencerId], references: [id])
  affiliateId     String?
  affiliate       Affiliate?       @relation(fields: [affiliateId], references: [id])

  walletAddress   String
  ezziAmount      Decimal          @db.Decimal(18, 9)
  method          PayoutMethod     @default(EZZI_COIN)
  status          WithdrawalStatus @default(REQUESTED)

  requestedAt     DateTime         @default(now())
  processedAt     DateTime?
  txSignature     String?
  adminNote       String?

  @@index([status])
}

model Campaign {
  id              String       @id @default(cuid())
  title           String
  description     String?
  productFocus    String
  bonusEzzi       Int          @default(0)
  targetSales     Int          @default(100)
  currentSales    Int          @default(0)
  startsAt        DateTime
  endsAt          DateTime
  isActive        Boolean      @default(true)

  influencers     Influencer[]

  createdAt       DateTime     @default(now())
}
