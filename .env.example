# ============================================
# EZZI WORLD - Environment Configuration
# ============================================

# ============================================
# API (Backend)
# ============================================
NODE_ENV=development
PORT=3001

# Database (use SQLite for dev, PostgreSQL for prod)
DATABASE_URL="file:./dev.db"
DIRECT_URL="file:./dev.db"
# For PostgreSQL (production):
# DATABASE_URL="postgresql://user:pass@localhost:5432/ezzi_world"
# DIRECT_URL="postgresql://user:pass@localhost:5432/ezzi_world"

# JWT Secrets (generate strong random strings)
JWT_SECRET="your-jwt-secret-min-32-characters"
HMAC_SECRET="your-hmac-secret-min-32-characters"
COOKIE_SECRET="your-cookie-secret-min-32-characters"

# Solana
SOLANA_RPC_URL="https://api.devnet.solana.com"
SOLANA_NETWORK="devnet" # devnet, testnet, mainnet

# Helius (for webhooks and enhanced RPC)
HELIUS_RPC_URL="https://devnet.helius-rpc.com/?api-key=your-api-key"
HELIUS_API_KEY="your-helius-api-key"
HELIUS_WEBHOOK_SECRET="your-webhook-secret"

# Wallets (use different wallets for each purpose)
NFT_WALLET="your-nft-mint-wallet-address"
CAPSULE_WALLET="your-capsule-sales-wallet-address"
TOKEN_WALLET="your-token-wallet-address"

# Program IDs (after deploying Anchor programs)
NFT_PROGRAM_ID="Fg6PaFpoGXkYsidMpWTK6W2BeZ7FEfcYkg476zPFsLnS"
MARKETPLACE_PROGRAM_ID="HjrMEZ7aWLFrX7t1L9p1Q7JkG1f7b7r9q7Y9Z9p9k9p9"
TOKEN_PROGRAM_ID="ToKLxTk67d7b7r9q7Y9Z9p9k9p9k9p9k9p9k9p9k9p9"

# Redis (Upstash for production)
REDIS_URL="redis://default:password@localhost:6379"
# Production: REDIS_URL="rediss://default:pass@host.upstash.io:6379"

# ============================================
# WEB (Frontend)
# ============================================
NEXT_PUBLIC_API_URL="http://localhost:3001/api"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
NEXT_PUBLIC_SOLANA_RPC="https://api.devnet.solana.com"
NEXT_PUBLIC_SOLANA_NETWORK="devnet"
NEXT_PUBLIC_NFT_PROGRAM_ID="Fg6PaFpoGXkYsidMpWTK6W2BeZ7FEfcYkg476zPFsLnS"
NEXT_PUBLIC_MARKETPLACE_PROGRAM_ID="HjrMEZ7aWLFrX7t1L9p1Q7JkG1f7b7r9q7Y9Z9p9k9p9"
NEXT_PUBLIC_TOKEN_PROGRAM_ID="ToKLxTk67d7b7r9q7Y9Z9p9k9p9k9p9k9p9k9p9k9p9"

# ============================================
# TELEGRAM BOT
# ============================================
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_BOT_SECRET="your-telegram-bot-secret"

# ============================================
# PLATFORM SETTINGS
# ============================================
ALLOWED_ORIGINS="http://localhost:3000,https://ezzi.trade"
BLOCKED_COUNTRIES=""
COMMISSION_LOCK_DAYS=30

# Admin
ADMIN_EMAIL="admin@ezzi.trade"
ADMIN_WALLET="your-admin-wallet-address"

# ============================================
# NFT GENERATION
# ============================================
NFT_METADATA_BASE_URL="https://nft.ezzi.trade"
IPFS_GATEWAY="https://ipfs.io/ipfs"
ARWEAVE_GATEWAY="https://arweave.net"

# OpenAI (for NFT generation if using AI)
OPENAI_API_KEY="your-openai-api-key"

# Pinata (for IPFS uploads)
PINATA_API_KEY="your-pinata-api-key"
PINATA_API_SECRET="your-pinata-api-secret"
