# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ezzi_world?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/ezzi_world?schema=public"

# Redis (Upstash)
REDIS_URL="redis://default:password@host:6379"

# JWT Secrets
JWT_SECRET="your-jwt-secret-here-min-32-chars"
HMAC_SECRET="your-hmac-secret-here-min-32-chars"
COOKIE_SECRET="your-cookie-secret-here-min-32-chars"

# Solana
SOLANA_NETWORK="devnet"
SOLANA_RPC_URL="https://api.devnet.solana.com"
HELIUS_RPC_URL="https://devnet.helius-rpc.com/?api-key=your-api-key"
HELIUS_API_KEY="your-helius-api-key"
HELIUS_WEBHOOK_SECRET="your-webhook-secret"

# NFT Collection (Metaplex)
NFT_COLLECTION_ADDRESS="your-collection-mint-address"
TREASURY_WALLET="your-treasury-wallet-address"
NFT_WALLET_PRIVATE_KEY="base64-encoded-private-key-for-minting"

# Wallets (use different wallets for each)
NFT_WALLET="your-nft-wallet-address"
CAPSULE_WALLET="your-capsule-wallet-address"
TOKEN_WALLET="your-token-wallet-address"

# Platform Settings
ALLOWED_ORIGINS="http://localhost:3000,https://your-domain.com"
PORT=3001
NODE_ENV="development"

# Admin
ADMIN_EMAIL="admin@ezzi.trade"

# Blocked Countries (comma-separated ISO codes)
BLOCKED_COUNTRIES=""

# Commission Lock Days
COMMISSION_LOCK_DAYS=30
