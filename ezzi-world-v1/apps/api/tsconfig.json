{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "paths": {
      "@ezzi/shared": ["../../packages/shared/dist"],
      "@ezzi/shared/*": ["../../packages/shared/dist/*"]
    }
  },
  "include": ["src/**/*", "prisma/**/*"],
  "exclude": ["dist", "node_modules"],
  "references": [
    { "path": "../../packages/shared" }
  ]
}
